    <script>
      function setTheme(theme) {
        document.body.classList.remove('theme-new-brand');
        if (theme === 'new-brand') document.body.classList.add('theme-new-brand');
        
        const themeBtnContainer = document.querySelectorAll('.evaluator-options')[0];
        themeBtnContainer.querySelectorAll('.evaluator-opt').forEach(b => b.classList.remove('active'));
        themeBtnContainer.querySelector(`button[onclick="setTheme('${theme}')"]`).classList.add('active');
        
        const metaTheme = document.querySelector('meta[name="theme-color"]');
        if (metaTheme) metaTheme.content = theme === 'new-brand' ? '#006060' : '#0da99b';
      }

      function setLogo(logo) {
        document.body.setAttribute('data-logo-state', logo);
        
        const logoBtnContainer = document.querySelectorAll('.evaluator-options')[1];
        logoBtnContainer.querySelectorAll('.evaluator-opt').forEach(b => b.classList.remove('active'));
        logoBtnContainer.querySelector(`button[onclick="setLogo('${logo}')"]`).classList.add('active');
      }

      function toggleEvaluator() {
        const panel = document.getElementById('design-evaluator');
        panel.classList.toggle('minimized');
        const btn = panel.querySelector('.evaluator-toggle-btn');
        btn.textContent = panel.classList.contains('minimized') ? '+' : '−';
      }

      // Init
      setLogo('original');
    </script>
    <script src="script.js"></script>
  </body>
</html>
